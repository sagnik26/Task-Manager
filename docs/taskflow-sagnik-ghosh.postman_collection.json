{
  "info": {
    "_postman_id": "taskflow-api-collection",
    "name": "TaskFlow API",
    "description": "TaskFlow REST API. Set `baseUrl` (local: http://localhost:4000, prod: your Railway URL).\n\n**Auth:** Run **Login** or **Register** first — the test script saves `data.token` to `{{token}}`. Protected routes use Bearer `{{token}}`. The API also sets an `authToken` cookie (enable Postman cookies for cookie-based auth).\n\n**Seed user (after seed.sql):** `test@example.com` / `password123`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "projectId",
      "value": ""
    },
    {
      "key": "taskId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}",
                  "if (json.data && json.data.user && json.data.user.id) {",
                  "  pm.collectionVariables.set('userId', json.data.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}",
                  "if (json.data && json.data.user && json.data.user.id) {",
                  "  pm.collectionVariables.set('userId', json.data.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Seed credentials (after seed.sql): test@example.com / password123"
          },
          "response": []
        },
        {
          "name": "Get profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/profile"
          },
          "response": []
        },
        {
          "name": "Get permissions",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/permissions"
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/auth/logout",
            "description": "Clears authToken cookie."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List projects",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/projects"
          },
          "response": []
        },
        {
          "name": "Create project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('projectId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"My Project\",\n  \"description\": \"Optional description\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/projects",
            "description": "Requires permission: create:project (admin)."
          },
          "response": []
        },
        {
          "name": "Get project detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/projects/{{projectId}}"
          },
          "response": []
        },
        {
          "name": "Get project stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/projects/{{projectId}}/stats",
            "description": "Task counts by status and by assignee."
          },
          "response": []
        },
        {
          "name": "List project members",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/projects/{{projectId}}/members"
          },
          "response": []
        },
        {
          "name": "Update project",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated name\",\n  \"description\": \"Updated description\",\n  \"status\": \"active\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/projects/{{projectId}}",
            "description": "status: active | archived"
          },
          "response": []
        },
        {
          "name": "Delete project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/projects/{{projectId}}",
            "description": "Requires permission: delete:project (admin)."
          },
          "response": []
        },
        {
          "name": "Add project member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{userId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/projects/{{projectId}}/members",
            "description": "Requires permission: manage:project_members (admin)."
          },
          "response": []
        },
        {
          "name": "Remove project member",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/projects/{{projectId}}/members/{{userId}}",
            "description": "Requires permission: manage:project_members (admin)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List tasks by project",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks"
          },
          "response": []
        },
        {
          "name": "List tasks — filter by status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?status=todo",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"],
              "query": [{ "key": "status", "value": "todo" }]
            },
            "description": "status: todo | in_progress | done"
          },
          "response": []
        },
        {
          "name": "List tasks — filter by assignee",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?assignee={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"],
              "query": [{ "key": "assignee", "value": "{{userId}}" }]
            }
          },
          "response": []
        },
        {
          "name": "List tasks — filter by status and assignee",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?status=in_progress&assignee={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["projects", "{{projectId}}", "tasks"],
              "query": [
                { "key": "status", "value": "in_progress" },
                { "key": "assignee", "value": "{{userId}}" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('taskId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New task\",\n  \"description\": \"Optional\",\n  \"status\": \"todo\",\n  \"priority\": \"medium\",\n  \"assignee_id\": null,\n  \"due_date\": \"2026-12-31\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks",
            "description": "status: todo | in_progress | done. priority: low | medium | high. due_date: YYYY-MM-DD."
          },
          "response": []
        },
        {
          "name": "Update task",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated task\",\n  \"status\": \"in_progress\",\n  \"priority\": \"high\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          },
          "response": []
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "description": "Admin, or project member who created the task."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/users",
            "description": "Requires permission: manage:users (admin)."
          },
          "response": []
        },
        {
          "name": "Update user",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"developer\",\n  \"is_active\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/users/{{userId}}",
            "description": "Requires permission: manage:users (admin). role: admin | developer."
          },
          "response": []
        }
      ]
    }
  ]
}
