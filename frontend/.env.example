# API base URL baked in at build time.
# Local Docker / Netlify proxy: /api
# Direct backend URL (requires CORS + cookie config): https://your-api.example.com
VITE_API_URL=/api

# Netlify only (build-time): origin of the Express backend, no trailing slash.
# Proxies /api/* → BACKEND_PROXY_URL/* in dist/_redirects (same as nginx in Docker).
# BACKEND_PROXY_URL=https://your-api.example.com
