# API base URL baked in at build time.
# Local Docker / Vercel proxy: /api
# Direct backend URL (requires CORS + cookie config): https://your-api.example.com
NEXT_PUBLIC_API_URL=/api

# Server-only (runtime): origin of the Express backend, no trailing slash.
# Proxies /api/* via src/middleware.ts (Vercel) or next.config rewrites (local dev).
# BACKEND_PROXY_URL=https://your-api.example.com
